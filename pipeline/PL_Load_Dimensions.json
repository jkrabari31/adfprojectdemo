								},
								"sink": {
									"name": "State",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "Country",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "Country",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "CustomerSegment",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "CustomerSegment",
									"type": "String",
									"physicalType": "nvarchar"
								}
