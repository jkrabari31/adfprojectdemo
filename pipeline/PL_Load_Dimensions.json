{
	"name": "PL_Load_Dimensions",
	"properties": {
		"description": "Full load of customer and product dimension blob to SQL",
		"activities": [
			{
				"name": "Copy_Customers",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.00:30:00",
					"retry": 2,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
