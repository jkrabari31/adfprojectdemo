{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-shopeasy-2024"
		},
		"LS_AzureSQL_Shopeasy_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AzureSQL_Shopeasy'"
		},
		"Ls_Blobstorage_Shopeasy_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Ls_Blobstorage_Shopeasy'"
		},
		"LS_AzureSQL_Shopeasy_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-shopeasy-2024.database.windows.net"
		},
		"LS_AzureSQL_Shopeasy_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "shopeasy-dw"
		},
		"LS_AzureSQL_Shopeasy_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-shopeasy-2024_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AzureSQL_Shopeasy_password": {
						"value": "[parameters('LS_AzureSQL_Shopeasy_password')]"
					},
					"Ls_Blobstorage_Shopeasy_connectionString": {
						"value": "[parameters('Ls_Blobstorage_Shopeasy_connectionString')]"
					},
					"LS_AzureSQL_Shopeasy_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Shopeasy_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Shopeasy_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Shopeasy_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Shopeasy_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Shopeasy_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}